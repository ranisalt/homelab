[Container]
ContainerName=%N
DropCapability=NET_RAW
HealthCmd=redis-cli ping || exit 1
Image=docker.io/valkey/valkey@sha256:546304417feac0874c3dd576e0952c6bb8f06bb4093ea0c9ca303c73cf458f63
Network=immich-redis.network
NoNewPrivileges=yes
User=1000:1000
Volume=immich-redis.volume:/data:U,Z

[Service]
Restart=always
